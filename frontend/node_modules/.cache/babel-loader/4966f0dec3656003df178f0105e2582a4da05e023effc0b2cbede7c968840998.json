{"ast":null,"code":"import axios from 'axios';\nconst API_URL = 'http://localhost:8080/api';\nexport default {\n  name: 'App',\n  data() {\n    return {\n      userId: 1001,\n      // 模拟用户ID\n      products: [{\n        id: 1,\n        name: 'iPhone 15 Pro',\n        originalPrice: 8999,\n        seckillPrice: 6999,\n        stock: 100,\n        image: 'https://picsum.photos/200'\n      }, {\n        id: 2,\n        name: 'MacBook Pro',\n        originalPrice: 15999,\n        seckillPrice: 12999,\n        stock: 50,\n        image: 'https://picsum.photos/201'\n      }, {\n        id: 3,\n        name: 'AirPods Pro',\n        originalPrice: 1999,\n        seckillPrice: 999,\n        stock: 200,\n        image: 'https://picsum.photos/202'\n      }],\n      seckillTime: null,\n      // 秒杀开始时间\n      canSeckill: false,\n      loading: false,\n      dialogVisible: false,\n      orderResult: null,\n      countDown: '00:00:00'\n    };\n  },\n  mounted() {\n    // 模拟设置秒杀开始时间（5秒后）\n    this.seckillTime = new Date(Date.now() + 5000);\n    this.startCountDown();\n  },\n  methods: {\n    startCountDown() {\n      setInterval(() => {\n        const now = new Date();\n        const diff = this.seckillTime - now;\n        if (diff <= 0) {\n          this.canSeckill = true;\n          this.countDown = '00:00:00';\n          return;\n        }\n        const hours = Math.floor(diff / (1000 * 60 * 60));\n        const minutes = Math.floor(diff % (1000 * 60 * 60) / (1000 * 60));\n        const seconds = Math.floor(diff % (1000 * 60) / 1000);\n        this.countDown = `${hours.toString().padStart(2, '0')}:${minutes.toString().padStart(2, '0')}:${seconds.toString().padStart(2, '0')}`;\n      }, 1000);\n    },\n    async handleSeckill(productId) {\n      this.loading = true;\n      try {\n        const response = await axios.post(`${API_URL}/seckill/${productId}`, {}, {\n          headers: {\n            'userId': this.userId\n          }\n        });\n        if (response.data.code === 200) {\n          this.orderResult = {\n            status: 'SUCCESS',\n            orderNo: response.data.data\n          };\n          this.dialogVisible = true;\n\n          // 延迟查询订单状态\n          setTimeout(() => {\n            this.queryOrderResult(response.data.data);\n          }, 2000);\n        }\n      } catch (error) {\n        this.$message.error(error.response?.data?.message || '秒杀失败');\n      } finally {\n        this.loading = false;\n      }\n    },\n    async queryOrderResult(orderNo) {\n      try {\n        const response = await axios.get(`${API_URL}/seckill/result/${orderNo}`);\n        this.orderResult = {\n          status: response.data.data?.status === 'PAID' ? 'SUCCESS' : 'PROCESSING',\n          orderNo: orderNo\n        };\n      } catch (error) {\n        console.error('查询订单失败:', error);\n      }\n    }\n  }\n};","map":{"version":3,"names":["axios","API_URL","name","data","userId","products","id","originalPrice","seckillPrice","stock","image","seckillTime","canSeckill","loading","dialogVisible","orderResult","countDown","mounted","Date","now","startCountDown","methods","setInterval","diff","hours","Math","floor","minutes","seconds","toString","padStart","handleSeckill","productId","response","post","headers","code","status","orderNo","setTimeout","queryOrderResult","error","$message","message","get","console"],"sources":["src/App.vue"],"sourcesContent":["<template>\n  <div id=\"app\">\n    <el-container>\n      <!-- 头部 -->\n      <el-header class=\"header\">\n        <div class=\"header-content\">\n          <h1>⚡ 秒杀系统</h1>\n          <div class=\"user-info\">\n            <span>用户: {{ userId }}</span>\n          </div>\n        </div>\n      </el-header>\n      \n      <el-main>\n        <!-- 倒计时 -->\n        <div class=\"countdown\" v-if=\"seckillTime\">\n          <span>距离开抢还剩:</span>\n          <span class=\"time\">{{ countDown }}</span>\n        </div>\n        \n        <!-- 商品列表 -->\n        <el-row :gutter=\"20\">\n          <el-col :span=\"8\" v-for=\"product in products\" :key=\"product.id\">\n            <el-card class=\"product-card\">\n              <img :src=\"product.image\" class=\"product-image\">\n              <h3>{{ product.name }}</h3>\n              <p class=\"price\">\n                <span class=\"original\">¥{{ product.originalPrice }}</span>\n                <span class=\"seckill\">秒杀价 ¥{{ product.seckillPrice }}</span>\n              </p>\n              <p class=\"stock\">库存: {{ product.stock }}</p>\n              <el-button \n                type=\"danger\" \n                size=\"large\" \n                :disabled=\"!canSeckill\"\n                :loading=\"loading\"\n                @click=\"handleSeckill(product.id)\"\n                class=\"seckill-btn\"\n              >\n                {{ canSeckill ? '立即秒杀' : '即将开始' }}\n              </el-button>\n            </el-card>\n          </el-col>\n        </el-row>\n        \n        <!-- 订单结果 -->\n        <el-dialog v-model=\"dialogVisible\" title=\"秒杀结果\" width=\"400px\">\n          <div v-if=\"orderResult\">\n            <el-result\n              :icon=\"orderResult.status === 'SUCCESS' ? 'success' : 'warning'\"\n              :title=\"orderResult.status === 'SUCCESS' ? '秒杀成功!' : '处理中'\"\n            >\n              <template slot=\"subTitle\">\n                <p v-if=\"orderResult.orderNo\">订单号: {{ orderResult.orderNo }}</p>\n                <p v-if=\"orderResult.status === 'PROCESSING'\">请稍候查询结果...</p>\n              </template>\n            </el-result>\n          </div>\n        </el-dialog>\n      </el-main>\n    </el-container>\n  </div>\n</template>\n\n<script>\nimport axios from 'axios'\n\nconst API_URL = 'http://localhost:8080/api'\n\nexport default {\n  name: 'App',\n  data() {\n    return {\n      userId: 1001, // 模拟用户ID\n      products: [\n        { id: 1, name: 'iPhone 15 Pro', originalPrice: 8999, seckillPrice: 6999, stock: 100, image: 'https://picsum.photos/200' },\n        { id: 2, name: 'MacBook Pro', originalPrice: 15999, seckillPrice: 12999, stock: 50, image: 'https://picsum.photos/201' },\n        { id: 3, name: 'AirPods Pro', originalPrice: 1999, seckillPrice: 999, stock: 200, image: 'https://picsum.photos/202' }\n      ],\n      seckillTime: null, // 秒杀开始时间\n      canSeckill: false,\n      loading: false,\n      dialogVisible: false,\n      orderResult: null,\n      countDown: '00:00:00'\n    }\n  },\n  mounted() {\n    // 模拟设置秒杀开始时间（5秒后）\n    this.seckillTime = new Date(Date.now() + 5000)\n    this.startCountDown()\n  },\n  methods: {\n    startCountDown() {\n      setInterval(() => {\n        const now = new Date()\n        const diff = this.seckillTime - now\n        \n        if (diff <= 0) {\n          this.canSeckill = true\n          this.countDown = '00:00:00'\n          return\n        }\n        \n        const hours = Math.floor(diff / (1000 * 60 * 60))\n        const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60))\n        const seconds = Math.floor((diff % (1000 * 60)) / 1000)\n        \n        this.countDown = `${hours.toString().padStart(2, '0')}:${minutes.toString().padStart(2, '0')}:${seconds.toString().padStart(2, '0')}`\n      }, 1000)\n    },\n    \n    async handleSeckill(productId) {\n      this.loading = true\n      \n      try {\n        const response = await axios.post(`${API_URL}/seckill/${productId}`, {}, {\n          headers: { 'userId': this.userId }\n        })\n        \n        if (response.data.code === 200) {\n          this.orderResult = {\n            status: 'SUCCESS',\n            orderNo: response.data.data\n          }\n          this.dialogVisible = true\n          \n          // 延迟查询订单状态\n          setTimeout(() => {\n            this.queryOrderResult(response.data.data)\n          }, 2000)\n        }\n      } catch (error) {\n        this.$message.error(error.response?.data?.message || '秒杀失败')\n      } finally {\n        this.loading = false\n      }\n    },\n    \n    async queryOrderResult(orderNo) {\n      try {\n        const response = await axios.get(`${API_URL}/seckill/result/${orderNo}`)\n        this.orderResult = {\n          status: response.data.data?.status === 'PAID' ? 'SUCCESS' : 'PROCESSING',\n          orderNo: orderNo\n        }\n      } catch (error) {\n        console.error('查询订单失败:', error)\n      }\n    }\n  }\n}\n</script>\n\n<style lang=\"scss\">\n#app {\n  min-height: 100vh;\n  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);\n}\n\n.header {\n  background: linear-gradient(90deg, #ff4757, #ff6b81);\n  color: white;\n  display: flex;\n  align-items: center;\n  \n  .header-content {\n    width: 100%;\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    \n    h1 { font-size: 24px; margin: 0; }\n  }\n}\n\n.countdown {\n  text-align: center;\n  padding: 20px;\n  color: white;\n  font-size: 18px;\n  \n  .time {\n    font-size: 32px;\n    font-weight: bold;\n    color: #ffd700;\n    margin-left: 10px;\n  }\n}\n\n.product-card {\n  margin-bottom: 20px;\n  text-align: center;\n  \n  .product-image {\n    width: 100%;\n    height: 150px;\n    object-fit: cover;\n  }\n  \n  .price {\n    .original { text-decoration: line-through; color: #999; margin-right: 10px; }\n    .seckill { color: #ff4757; font-size: 24px; font-weight: bold; }\n  }\n  \n  .stock { color: #666; }\n  \n  .seckill-btn {\n    width: 100%;\n    font-size: 18px;\n    font-weight: bold;\n  }\n}\n</style>\n"],"mappings":"AAiEA,OAAAA,KAAA;AAEA,MAAAC,OAAA;AAEA;EACAC,IAAA;EACAC,KAAA;IACA;MACAC,MAAA;MAAA;MACAC,QAAA,GACA;QAAAC,EAAA;QAAAJ,IAAA;QAAAK,aAAA;QAAAC,YAAA;QAAAC,KAAA;QAAAC,KAAA;MAAA,GACA;QAAAJ,EAAA;QAAAJ,IAAA;QAAAK,aAAA;QAAAC,YAAA;QAAAC,KAAA;QAAAC,KAAA;MAAA,GACA;QAAAJ,EAAA;QAAAJ,IAAA;QAAAK,aAAA;QAAAC,YAAA;QAAAC,KAAA;QAAAC,KAAA;MAAA,EACA;MACAC,WAAA;MAAA;MACAC,UAAA;MACAC,OAAA;MACAC,aAAA;MACAC,WAAA;MACAC,SAAA;IACA;EACA;EACAC,QAAA;IACA;IACA,KAAAN,WAAA,OAAAO,IAAA,CAAAA,IAAA,CAAAC,GAAA;IACA,KAAAC,cAAA;EACA;EACAC,OAAA;IACAD,eAAA;MACA